# ============================================================
# RCF — Recruiter Contact Finder: Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# Only keys for sources you enable in config.yml are required.
# Sources without an api_key_env field (scrapers, browser, local tools)
# need no key — they work out of the box.
#
# NEVER commit .env to version control. It should be in .gitignore.
# ============================================================


# ── General Application Settings ─────────────────────────────
# Override config.yml defaults via environment variables (optional).

# LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# DATABASE_PATH=rcf_data.db
# SQLite database file path (relative to project root or absolute)

# LOG_FILE=rcf.log
# Log file path (relative to project root or absolute)


# ── MCP Server Settings (Node.js) ────────────────────────────

# WORKSPACE_ROOT=
# Root directory for the MCP server workspace. Defaults to cwd.

# OMG_CONTEXT_THRESHOLD=400000
# Byte threshold for context checkpoint triggers in OMG orchestration


# ============================================================
# EMAIL DISCOVERY APIs
# ============================================================
# These find recruiter email addresses from company name / person name.

# Hunter — Email finder and verifier by domain
# Get key: https://hunter.io/api-keys
# Free tier: 50 credits/month
HUNTER_API_KEY=

# Apollo — B2B contact and company data platform
# Get key: https://app.apollo.io/settings/api-keys
# Free tier: 60 credits/month
APOLLO_API_KEY=

# Snov.io — Email finder, verifier, and drip campaign tool
# Get key: https://snov.io/profile/settings/api
# Free tier: 50 credits/month
SNOV_API_KEY=

# Seamless.AI — Real-time B2B contact data
# Get key: https://app.seamless.ai/settings/api
# Free tier: 50 lifetime credits
SEAMLESS_AI_KEY=

# Tomba — Email finder and verifier (disabled by default)
# Get key: https://app.tomba.io/api
# Free tier: 25 credits/month
TOMBA_API_KEY=

# RocketReach — Professional contact lookup, email and phone finder
# Get key: https://rocketreach.co/account/api
# Free tier: 25 credits/month
ROCKETREACH_API_KEY=

# PeopleDataLabs — Person search and company enrichment API
# Get key: https://www.peopledatalabs.com/dashboard/api-keys
# Free tier: 100 enrichment credits/month
PDL_API_KEY=


# ============================================================
# EMAIL VERIFICATION APIs
# ============================================================
# These verify if discovered emails are valid and deliverable.
# At least ONE is recommended for high-quality results.

# ZeroBounce — Email validation and scoring service (recommended)
# Get key: https://www.zerobounce.net/members/apikey/
# Free tier: 100 credits/month
ZEROBOUNCE_API_KEY=

# NeverBounce — Real-time email verification (disabled by default)
# Get key: https://app.neverbounce.com/settings/api-keys
# Free tier: 1000 one-time free credits
NEVERBOUNCE_API_KEY=

# Kickbox — Email deliverability verification (disabled by default)
# Get key: https://open.kickbox.com/
# Free tier: 100 credits/month
KICKBOX_API_KEY=


# ============================================================
# PHONE & LOCATION APIs
# ============================================================
# Google Places is HIGHLY recommended — it finds recruitment agencies
# with phone numbers, addresses, and websites via Google Maps.

# Google Places — Company search, phone, address, and website data
# Get key: https://console.cloud.google.com/apis/credentials
# Enable "Places API" in Google Cloud Console
# Free tier: $200/month free credit (~40K basic calls)
GOOGLE_PLACES_API_KEY=

# Abstract API — Email verification and phone validation (disabled by default)
# Get key: https://app.abstractapi.com/api/email-validation
# Free tier: 100 credits/month
ABSTRACT_API_KEY=


# ============================================================
# SOCIAL & OSINT APIs
# ============================================================

# HaveIBeenPwned — Breach database for email verification signal (disabled by default)
# Get key: https://haveibeenpwned.com/API/Key
# Paid: $3.50/month — the only paid service, entirely optional
HIBP_API_KEY=

# WhatsApp API — WhatsApp Business number presence checking
# Get key: https://developers.facebook.com/docs/whatsapp/business-management-api
# Note: Basic wa.me-based checking works without an API key
WHATSAPP_API_KEY=


# ============================================================
# NO API KEY NEEDED (listed for reference)
# ============================================================
# The following sources are enabled by default and require no key:
#
#   Scrapers:    bayt, naukrigulf, gulf_talent, expatriates, dubizzle,
#                dmcc_directory, uae_yellow_pages, google_dorking
#   Browser:     linkedin (uses your personal login session)
#   Local tools: email_permutator, arabic_name_normalizer, uae_phone_detector
#   ATS APIs:    greenhouse, lever (public job board APIs)
#   Executive:   heidrick_and_struggles, korn_ferry, spencer_stuart,
#                egon_zehnder, russell_reynolds


# ============================================================
# QUICK START
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in at minimum: GOOGLE_PLACES_API_KEY
# 3. Run setup:       rcf setup
# 4. Test search:     rcf search "Google Dubai"
# ============================================================
